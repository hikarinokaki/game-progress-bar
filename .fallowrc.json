{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/public/js/main.js", "src/public/js/bar.js"],
  "duplicates": {
    "minOccurrences": 3
  },
  "rules": {
