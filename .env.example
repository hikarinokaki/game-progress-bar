# Steam Web API key — get yours at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Public-facing URL of your app (for Steam OpenID redirects)
# In production: https://progress.ookaminohikari.com
# In local dev: http://localhost:3000
BASE_URL=http://localhost:3000

# URL path prefix if app is behind a reverse proxy (e.g. /game-progress-bar)
# Leave empty for root-level access
BASE_PATH=

# Secret for signing session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_string

# Node environment: development or production
NODE_ENV=development

# Server port
PORT=3000
